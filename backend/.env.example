# Example environment variables file
# Copy this to .env and fill in your actual values

# Translation API Configuration
# Get an API key from your chosen translation service:
# - Google Translate: https://cloud.google.com/translate/docs
# - DeepL: https://www.deepl.com/docs-api
# - Azure Translator: https://learn.microsoft.com/en-us/azure/cognitive-services/translator/
# 
# If no API key is provided, the app will use mock translations for demo purposes

# TRANSLATION_API_KEY=your_api_key_here

# FastAPI Configuration
# Debug mode (set to false in production)
# DEBUG=true
